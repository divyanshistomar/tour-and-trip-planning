<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: title }) %>
  <style>
    .detail-hero { position:relative; height:380px; overflow:hidden; }
    .detail-hero img { width:100%; height:100%; object-fit:cover; }
    .detail-hero-overlay { position:absolute; inset:0; background:rgba(0,0,0,.45); }
    .detail-hero-text { position:absolute; bottom:32px; left:32px; color:#fff; }
    .detail-hero-text h1 { font-size:2.2rem; margin:0 0 8px; }
    .detail-body { max-width:900px; margin:40px auto; padding:0 20px; }
    .detail-grid { display:grid; grid-template-columns:1fr 320px; gap:32px; }
    .info-box { background:#f8f9fa; border-radius:12px; padding:24px; margin-bottom:24px; }
    .info-box h3 { margin:0 0 16px; color:#e74c3c; }
    .tag-list { display:flex; flex-wrap:wrap; gap:8px; }
    .tag { background:#e74c3c; color:#fff; padding:4px 12px; border-radius:20px; font-size:13px; }
    .tag-alt { background:#2c3e50; }
    .meta-row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid #eee; font-size:14px; }
    .price-card { background:#2c3e50; color:#fff; border-radius:12px; padding:28px; position:sticky; top:24px; }
    .price-big { font-size:2.4rem; font-weight:700; color:#e74c3c; }
    .back-link { display:inline-block; margin-bottom:24px; color:#e74c3c; text-decoration:none; font-weight:600; }
  </style>
</head>
<body>

<%- include('partials/navbar', { activePage: 'tours' }) %>


<div class="detail-hero">
  
  <img src="<%= tour.image %>" alt="<%= tour.title %>">
  <div class="detail-hero-overlay"></div>
  <div class="detail-hero-text">
    <span class="tour-badge" style="margin-bottom:10px;display:inline-block"><%= tour.category %></span>
    <h1><%= tour.title %></h1>
    <p>📍 <%= tour.destination %>, <%= tour.state %></p>
  </div>
</div>

<div class="detail-body">
  <a href="/ssr/tours" class="back-link">← Back to All Tours</a>

  <div class="detail-grid">
    
    <div>

      
      <div class="info-box">
        <h3>About This Tour</h3>
        <p><%= tour.description %></p>
      </div>

      
      <div class="info-box">
        <h3>✨ Highlights</h3>
        <ul>
          <% tour.highlights.forEach(function(h) { %>
            <li style="padding:4px 0;">✅ <%= h %></li>
          <% }) %>
        </ul>
      </div>

      
      <div class="info-box">
        <h3>🗺️ Attractions</h3>
        <div class="tag-list">
          <% tour.attractions.forEach(function(a) { %>
            <span class="tag"><%= a %></span>
          <% }) %>
        </div>
      </div>

      
      <div class="info-box">
        <h3>📦 What's Included</h3>
        <div class="tag-list">
          <% tour.includes.forEach(function(item) { %>
            <span class="tag tag-alt">✓ <%= item %></span>
          <% }) %>
        </div>
      </div>

    </div>

    
    <div>
      <div class="price-card">
        <p style="margin:0 0 4px; opacity:.7; font-size:13px;">Starting from</p>
        <div class="price-big">₹<%= tour.price.toLocaleString('en-IN') %></div>
        <p style="margin:0 0 20px; opacity:.7; font-size:13px;">per person</p>

        
        <div class="meta-row" style="color:#fff; border-color:#ffffff30;">
          <span>Duration</span><strong><%= tour.days %> Days</strong>
        </div>
        <div class="meta-row" style="color:#fff; border-color:#ffffff30;">
          <span>Difficulty</span>
          




          <strong style="color:<%= tour.difficulty === 'Easy' ? '#27ae60' : tour.difficulty === 'Moderate' ? '#f39c12' : '#e74c3c' %>">
            <%= tour.difficulty %>
          </strong>
        </div>
        <div class="meta-row" style="color:#fff; border-color:#ffffff30;">
          <span>Group Size</span><strong>Max <%= tour.groupSize %></strong>
        </div>
        <div class="meta-row" style="color:#fff; border-color:#ffffff30;">
          <span>Rating</span><strong>⭐ <%= tour.rating %> (<%= tour.reviews %> reviews)</strong>
        </div>
        <div class="meta-row" style="color:#fff; border-color:#ffffff30;">
          <span>Best Time</span><strong><%= tour.bestTime %></strong>
        </div>

        <a href="/booking?tourId=<%= tour.id %>" class="btn-primary"
           style="display:block; text-align:center; margin-top:24px; text-decoration:none;">
          Book This Tour
        </a>
      </div>
    </div>
  </div>

  
  <div style="background:#f8f9fa; border-radius:8px; padding:16px; margin-top:32px; font-size:13px; color:#555; border-left:4px solid #e74c3c;">
    <strong>📘 SSR Data Flow for this page:</strong><br>
    Route reads <code>tours.json</code> → finds tour with id=<strong><%= tour.id %></strong>
    → passes <code>{ tour }</code> to <code>res.render('ejs/tourDetail', ...)</code>
    → EJS substitutes all <code>&lt;%= %&gt;</code> tags → complete HTML sent to browser.<br>
    <em>Rendered at <%= renderTime %></em>
  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
