

# Server port
PORT=3000

# MongoDB connection string
# Local:   mongodb://localhost:27017/india-trip-planner
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/india-trip-planner
MONGO_URI=mongodb://localhost:27017/india-trip-planner

# Session secret — signs the session ID cookie
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# JWT secret — signs and verifies JWT tokens
# Use a DIFFERENT string from SESSION_SECRET
JWT_SECRET=change-this-jwt-secret-in-production-too

# JWT expiry
JWT_EXPIRES=7d

# Optional: API key to protect /api/* routes (leave blank for open access)
# API_KEY=my-secret-api-key

# Set to 'true' to enable maintenance mode (returns 503 for all routes)
# MAINTENANCE=false

# Set to 'production' for production mode (enables HTTPS-only cookies, less verbose errors)
# NODE_ENV=production
